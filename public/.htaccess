Options -Indexes
RewriteEngine On
RewriteBase /

# Keep API and logs routes handled by server files
RewriteRule ^api/ - [L]
RewriteRule ^logs/ - [L]

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Don't rewrite common static asset requests
RewriteCond %{REQUEST_URI} \.(?:css|js|mjs|map|json|png|jpe?g|gif|svg|webp|ico|woff2?|ttf|eot|txt|xml|pdf|mp4|webm)$ [NC]
RewriteRule ^ - [L]

# SPA fallback
RewriteRule ^ index.html [L]

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|gif|svg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
